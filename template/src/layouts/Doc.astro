---
import Nav from '../components/Nav.astro';
import '../styles/theme.css';

const { title, date, status } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — house-rules</title>
    <!-- KaTeX CSS for rehype-katex output -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css"
    />
  </head>
  <body>
    <div class="hr-layout">
      <aside class="hr-sidebar"><Nav /></aside>
      <main class="hr-main">
        <header class="hr-doc-header">
          <h1>{title}</h1>
          <p class="hr-doc-meta">
            {date && <span>{date}</span>}
            {status && <span class="hr-badge">{status}</span>}
          </p>
        </header>
        <article class="hr-prose">
          <slot />
        </article>
      </main>
    </div>

    <!-- Mermaid renders <pre class="mermaid"> blocks client-side -->
    <script type="module">
      import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';
      mermaid.initialize({ startOnLoad: true, theme: 'dark' });
    </script>
  </body>
</html>
