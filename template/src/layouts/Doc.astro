---
import Nav from '../components/Nav.astro';
import { getCollection } from 'astro:content';
import '../styles/theme.css';

const { id = '', title, date, status } = Astro.props;

const MONTHS = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
const fmtDate = (d) => {
  if (!d) return null;
  const [y, m, day] = String(d).split('-');
  if (!y || !m || !day) return String(d);
  return `${MONTHS[+m - 1]} ${+day}, ${y}`;
};

// Canonical doc order within a piece; unknown leaves fall after, alpha.
const ORDER = ['spec', 'plan', 'context', 'exploration'];
const rank = (leaf) => {
  const i = ORDER.indexOf(leaf);
  return i === -1 ? ORDER.length : i;
};
const byLeaf = (a, b) => rank(a.leaf) - rank(b.leaf) || a.leaf.localeCompare(b.leaf);

// A piece = the top-level content-tree folder. Root-level docs (no folder) are
// their own single-doc piece, keyed by filename, so they stay reachable.
const pieceOf = (docId) => {
  const parts = docId.split('/');
  return parts.length > 1 ? parts[0] : parts[0];
};
const leafOf = (docId) => docId.split('/').slice(1).join('/') || docId;

const docs = await getCollection('docs');
const groups = new Map();
for (const d of docs) {
  const g = pieceOf(d.id);
  if (!groups.has(g)) groups.set(g, []);
  groups.get(g).push({ id: d.id, leaf: leafOf(d.id), date: d.data.date });
}

const piece = id ? pieceOf(id) : null;
const isFolderPiece = id ? id.split('/').length > 1 : false;

// Palette rows (pieces), newest first.
const pieces = [...groups.entries()]
  .map(([name, items]) => {
    const ordered = [...items].sort(byLeaf);
    return {
      name,
      files: ordered.map((i) => i.leaf),
      count: ordered.length,
      dateLabel: fmtDate(ordered[0].date),
      href: `/${ordered[0].id}`,
      active: name === piece,
    };
  })
  .sort((a, b) => {
    const ad = groups.get(a.name)[0].date || '';
    const bd = groups.get(b.name)[0].date || '';
    return bd.localeCompare(ad) || a.name.localeCompare(b.name);
  });

// Within-piece tabs (only when the current doc lives in a folder).
const tabs = isFolderPiece
  ? [...(groups.get(piece) || [])]
      .sort(byLeaf)
      .map((d) => ({ leaf: d.leaf, href: `/${d.id}`, active: d.id === id }))
  : [];

const eyebrow = [isFolderPiece ? piece : null, status, fmtDate(date)]
  .filter(Boolean)
  .join(' · ');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — house-rules</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@400;500;600&family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,600&family=IBM+Plex+Mono:wght@400;500;600&display=swap"
    />
    <!-- KaTeX CSS for rehype-katex output -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css"
    />
  </head>
  <body>
    <Nav piece={piece} pieces={pieces} />

    <div class="hr-scroll">
      <div class="hr-read">
      <div class="hr-col">
        <header>
          {eyebrow && <div class="hr-eyebrow">{eyebrow}</div>}
          <h1 class="hr-title">{title}</h1>
          {tabs.length > 1 && (
            <nav class="hr-tabs">
              {tabs.map((t) => (
                <a href={t.href} class={`hr-tab${t.active ? ' is-active' : ''}`}>{t.leaf}</a>
              ))}
            </nav>
          )}
        </header>
        <article class="hr-prose">
          <slot />
        </article>
      </div>
      </div>
    </div>

    <!-- SideNotes: place each note in the right gutter, top-aligned to its
         in-flow anchor marker; nudge down to avoid overlap. Recompute after
         fonts load and on resize. Skipped when the gutter is collapsed. -->
    <script is:inline>
      (function () {
        const prose = document.querySelector('.hr-prose');
        if (!prose) return;
        const place = () => {
          const notes = [...prose.querySelectorAll('.hr-sn')];
          if (!notes.length) return;
          if (window.matchMedia('(max-width: 1000px)').matches) {
            notes.forEach((n) => (n.style.top = ''));
            return;
          }
          const base = prose.getBoundingClientRect().top + window.scrollY;
          let prevBottom = -Infinity;
          for (const note of notes) {
            const marker = note.previousElementSibling; // the <sup> anchor
            const ref = marker || note;
            let top = ref.getBoundingClientRect().top + window.scrollY - base;
            if (top < prevBottom + 14) top = prevBottom + 14; // no overlap
            note.style.top = top + 'px';
            prevBottom = top + note.offsetHeight;
          }
        };
        let t;
        const schedule = () => { clearTimeout(t); t = setTimeout(place, 60); };
        place();
        window.addEventListener('resize', schedule);
        window.addEventListener('load', place);
        if (document.fonts && document.fonts.ready) document.fonts.ready.then(place);
      })();
    </script>

    <!-- Mermaid renders <pre class="mermaid"> blocks client-side. Respect the
         active theme (data-theme override, else system preference). -->
    <script type="module">
      import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';
      const root = document.documentElement;
      const dark =
        root.dataset.theme === 'dark' ||
        (root.dataset.theme !== 'light' &&
          window.matchMedia('(prefers-color-scheme: dark)').matches);
      mermaid.initialize({
        startOnLoad: true,
        theme: dark ? 'dark' : 'base',
        themeVariables: dark
          ? {}
          : {
              primaryColor: '#f6e7d9',
              primaryBorderColor: '#e6c7a6',
              primaryTextColor: '#33302a',
              lineColor: '#c2540f',
              secondaryColor: '#fdfbf6',
              tertiaryColor: '#fdfbf6',
            },
      });
    </script>
  </body>
</html>
